# Copy to `.env` in the project root and fill in values as needed.
# Get a Gemini key: https://aistudio.google.com/apikey

GUIDE_AI_API_KEY=
GUIDE_AI_MODEL=gemini-3.1-flash-lite

# --- Split deploy (Vercel frontend + Render/Railway backend) ---
# Set on Vercel (Production) — baked into the Vite build at deploy time:
# VITE_API_BASE=https://bogie-flow.onrender.com
# VITE_WS_BASE=   # optional; defaults to wss://<API host>/ws

# Frontend API base (empty = relative URLs via Vite proxy in dev)
VITE_API_BASE=

# WebSocket base (empty = derive from API_BASE or current page host)
VITE_WS_BASE=

# --- Backend (Render / Railway / Docker) ---
# Comma-separated CORS origins for the FastAPI service
ALLOWED_ORIGINS=https://bogieflow.vercel.app,https://faraway-2026-japan.vercel.app

# HTTP port for production (Render/Railway set this automatically)
PORT=8000

# Optional: run live smoke tests against a deployed backend
# LIVE_BACKEND_URL=https://bogie-flow.onrender.com
# LIVE_VERCEL_ORIGIN=https://bogieflow.vercel.app
